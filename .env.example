# ── Shared ──────────────────────────────────────────────────────────
# Neon Postgres connection string (pooled). Both web + worker use this.
# Get it from: Neon dashboard → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dealradar?sslmode=require

# ── Worker only (Render → Environment) ──────────────────────────────
# Travelpayouts Data API — flight price source (D10; replaced Amadeus Self-Service,
# decommissioned 2026-07-17). One token, DealRadar's OWN account (separate from TravelHub).
# Get it from: travelpayouts.com dashboard → Developers → API token
TRAVELPAYOUTS_TOKEN=
# Affiliate marker (partner id) for deep links — same account; used from task 5 on
TRAVELPAYOUTS_MARKER=

# Resend (task 8 — leave empty until email build)
RESEND_API_KEY=

# ── Web only (Vercel → Environment Variables) ───────────────────────
# (none beyond DATABASE_URL yet — affiliate keys land in task 5)
